PORT=3333
NODE_ENV=development

# Numero do WhatsApp financeiro com DDI + DDD + numero. Exemplo: 5511999999999
VITE_WHATSAPP_NUMBER=

# Conexao Oracle do WINTHOR.
# Exemplo de connect string: 192.168.0.10:1521/WINT
ORACLE_USER=usuario_leitura
ORACLE_PASSWORD=senha
ORACLE_CONNECT_STRING=host:porta/service_name

# Pasta compartilhada onde o WINTHOR gera/salva PDFs de boleto.
BOLETO_FILE_BASE_PATH=\\10.0.1.3\winthor-share-file\Winthor

# true usa dados simulados; false consulta o Oracle.
USE_MOCK_DATA=true

# API oficial TOTVS/WTA WinThor.
# A documentacao de clientes indica o endpoint /api/wholesale/v1/customer/list.
# A documentacao publica nao informou um endpoint especifico para 2a via de boleto.
TOTVS_API_BASE_URL=http://servidor-wta:porta
TOTVS_API_BRANCH_ID=1
TOTVS_API_CUSTOMER_LIST_PATH=/api/wholesale/v1/customer/list

# Autenticacao: informe um token fixo OU configure login/senha.
# A TOTVS orienta converter a senha para MAIUSCULA e depois MD5 em letras maiusculas.
# TOTVS_API_TOKEN=
# TOTVS_API_LOGIN_PATH=/winthor/autenticacao/v1/login
# TOTVS_API_LOGIN_USER=
# TOTVS_API_LOGIN_PASSWORD=
# Use md5_upper para senha normal ou already_md5 se a senha ja estiver em MD5.
TOTVS_API_PASSWORD_MODE=md5_upper
TOTVS_API_LOGIN_USER_FIELD=login
TOTVS_API_LOGIN_PASSWORD_FIELD=senha
TOTVS_API_TOKEN_FIELD=accessToken

# Opcional: sobrescreva a SQL de titulos do WINTHOR sem alterar codigo.
# A SQL deve receber o bind :document e retornar os aliases abaixo quando existirem:
# ID, CUSTOMER_CODE, CUSTOMER_NAME, DOCUMENT, INVOICE_NUMBER, INSTALLMENT,
# DUE_DATE, AMOUNT, PAID_AMOUNT, PAYMENT_DATE, LINE_DIGITAVEL, BOLETO_URL, PDF_BASE64.
# WINTHOR_RECEIVABLES_SQL=
