# Copie estas variaveis para Railway/Render (painel Variables).
# NAO commite valores reais.

NODE_ENV=production
HOST=0.0.0.0
USE_MOCK_DATA=false

ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_CONNECT_STRING=

WINTHOR_DOCUMENT_COLUMN=CGCENT
RECEIVABLES_CACHE_TTL_MS=300000

